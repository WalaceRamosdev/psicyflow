{
  "expo": {
    "name": "PsychFlow",
    "slug": "psychflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.psychflow.app",
      "infoPlist": {
        "NSCameraUsageDescription": "PsychFlow precisa de acesso à câmera para realizar teleconsultas de forma segura.",
        "NSMicrophoneUsageDescription": "PsychFlow precisa de acesso ao microfone para áudio nas teleconsultas.",
        "NSFaceIDUsageDescription": "PsychFlow utiliza biometria facial para autenticação rápida e segura do profissional de psicologia."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.psychflow.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-local-authentication",
        {
          "faceIDPermissionDescription": "Permita que o PsychFlow use o Face ID para proteger as sessões clínicas dos pacientes."
        }
      ]
    ],
    "scheme": "psychflow",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "07970869-99e7-435f-92ad-c9529207bc88"
      }
    }
  }
}

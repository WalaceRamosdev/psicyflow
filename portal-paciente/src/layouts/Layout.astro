---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Agendamento de Consultas de Psicoterapia Seguras e Online" } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | PsychFlow</title>
    <meta name="description" content={description} />
    
    <!-- Typography: Google Fonts Outfit & Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="bg-gradient"></div>
    <div class="glow-orb-1"></div>
    <div class="glow-orb-2"></div>
    
    <main class="main-container">
      <slot />
    </main>

    <footer class="footer">
      <p>&copy; {new Date().getFullYear()} PsychFlow. Todos os direitos reservados. 🛡️ HIPAA & LGPD Compliant.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg-dark: #090D16;
    --card-bg: rgba(17, 24, 39, 0.7);
    --border-color: rgba(255, 255, 255, 0.08);
    --text-primary: #F8FAFC;
    --text-secondary: #94A3B8;
    
    /* Premium Health Tech Colors */
    --primary: #0D9488;
    --primary-glow: rgba(13, 148, 136, 0.35);
    --accent: #10B981;
    --accent-glow: rgba(16, 185, 129, 0.2);
    --danger: #EF4444;
    --success: #10B981;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    font-family: 'Inter', sans-serif;
    background-color: var(--bg-dark);
    color: var(--text-primary);
    min-height: 100vh;
    overflow-x: hidden;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Outfit', sans-serif;
    color: var(--text-primary);
  }

  /* Background Gradient and Glow effects */
  .bg-gradient {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: radial-gradient(circle at 50% -20%, #111b2d 0%, #090d16 100%);
    z-index: -3;
  }

  .glow-orb-1 {
    position: fixed;
    top: -200px;
    left: -200px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(13, 148, 136, 0.15) 0%, rgba(0, 0, 0, 0) 70%);
    z-index: -2;
    filter: blur(80px);
    pointer-events: none;
  }

  .glow-orb-2 {
    position: fixed;
    bottom: -150px;
    right: -150px;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.1) 0%, rgba(0, 0, 0, 0) 70%);
    z-index: -2;
    filter: blur(100px);
    pointer-events: none;
  }

  .main-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 20px 80px 20px;
    min-height: calc(100vh - 120px);
  }

  /* Glassmorphism containers */
  .glass-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 24px;
    padding: 32px;
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
  }

  .footer {
    text-align: center;
    padding: 24px;
    font-size: 13px;
    color: var(--text-secondary);
    border-top: 1px solid var(--border-color);
    background-color: rgba(9, 13, 22, 0.9);
  }

  /* Custom scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: var(--bg-dark);
  }
  ::-webkit-scrollbar-thumb {
    background: rgba(13, 148, 136, 0.3);
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: rgba(13, 148, 136, 0.5);
  }
</style>

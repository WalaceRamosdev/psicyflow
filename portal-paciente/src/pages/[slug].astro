---
import Layout from '../layouts/Layout.astro';
import { BookingCalendar } from '../components/BookingCalendar';

const { slug } = Astro.params;
---

<Layout title="Agendar Consulta" description="Escolha o melhor dia e horário para a sua sessão de psicoterapia segura e criptografada.">
  <div class="booking-wrapper">
    <!-- Header/Logo Brand -->
    <header class="brand-header">
      <div class="brand-logo">Psych<span>Flow</span></div>
      <div class="secure-badge-top">🔒 Ambiente Seguro e Criptografado</div>
    </header>

    <BookingCalendar client:load slug={slug} />
  </div>
</Layout>

<style>
  /* Local Styles for Booking Layout */
  .booking-wrapper {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .brand-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-bottom: 20px;
  }

  .brand-logo {
    font-size: 24px;
    font-weight: 800;
    font-family: 'Outfit', sans-serif;
    color: #F8FAFC;
    letter-spacing: -0.5px;
  }

  .brand-logo span {
    color: #0D9488;
  }

  .secure-badge-top {
    font-size: 12px;
    color: #10B981;
    background: rgba(16, 185, 129, 0.1);
    padding: 6px 12px;
    border-radius: 20px;
    border: 1px solid rgba(16, 185, 129, 0.2);
    font-weight: 600;
  }

  @media (max-width: 600px) {
    .brand-header {
      flex-direction: column;
      gap: 12px;
      align-items: center;
      text-align: center;
      padding-bottom: 16px;
    }
  }
</style>

<style is:global>
  /* LGPD Consent Section */
  .lgpd-consent-wrapper {
    margin: 20px 0 15px;
    padding: 14px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    text-align: left;
  }

  .lgpd-consent-label {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    cursor: pointer;
  }

  .lgpd-checkbox {
    width: 18px;
    height: 18px;
    accent-color: #0D9488;
    margin-top: 3px;
    cursor: pointer;
  }

  .lgpd-text {
    font-size: 12px;
    line-height: 1.6;
    color: #94A3B8;
  }

  .lgpd-text strong {
    color: #F8FAFC;
    font-weight: 600;
  }

  /* Grid and layout elements */
  .grid-layout {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 32px;
  }

  @media (max-width: 900px) {
    .grid-layout {
      grid-template-columns: 1fr;
    }
  }

  .profile-column {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .profile-card {
    display: flex;
    flex-direction: column;
  }

  .profile-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
  }

  .profile-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .therapist-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #0D9488;
    box-shadow: 0 0 20px rgba(13, 148, 136, 0.3);
    margin-bottom: 18px;
  }

  .therapist-name {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 4px;
    color: #F8FAFC;
  }

  .therapist-crp {
    font-size: 13px;
    color: #94A3B8;
    font-weight: 500;
  }

  .separator {
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin: 20px 0;
  }

  .therapist-bio {
    font-size: 14px;
    line-height: 1.6;
    color: #CBD5E1;
    text-align: justify;
  }

  .specialties-section {
    width: 100%;
    text-align: left;
    margin-top: 10px;
  }

  .specialties-section h4 {
    font-size: 14px;
    font-weight: 600;
    color: #F8FAFC;
    margin-bottom: 10px;
  }

  .specialties-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* Shimmer Loading Skeleton */
  .shimmer-bg {
    position: relative;
    overflow: hidden;
    height: 400px;
  }

  .shimmer-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    margin-bottom: 18px;
    animation: shimmerEffect 1.5s infinite linear;
  }

  .shimmer-line {
    width: 80%;
    height: 16px;
    background: rgba(255, 255, 255, 0.05);
    margin-bottom: 12px;
    border-radius: 4px;
    animation: shimmerEffect 1.5s infinite linear;
  }

  .shimmer-line.title {
    width: 60%;
    height: 24px;
  }

  .shimmer-line.subtitle {
    width: 40%;
    height: 14px;
  }

  .shimmer-line.text {
    width: 90%;
    height: 60px;
  }

  @keyframes shimmerEffect {
    0% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.6;
    }
    100% {
      opacity: 0.3;
    }
  }

  /* Booking Column loading state */
  .flex-center {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-height: 400px;
  }

  .loading-spinner-circle {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(13, 148, 136, 0.15);
    border-top-color: #0D9488;
    border-radius: 50%;
    animation: spin 1s infinite linear;
    margin-bottom: 16px;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .loading-text-widget {
    font-size: 14px;
    color: #94A3B8;
    font-weight: 500;
  }

  /* React Island styles mapping to Astro layout */
  .step-container {
    margin-bottom: 32px;
  }

  .step-title {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 16px;
    color: #F8FAFC;
  }

  /* Date chips grid */
  .dates-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    gap: 12px;
  }

  .date-chip {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 12px 6px;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .date-chip:hover {
    background: rgba(13, 148, 136, 0.1);
    border-color: rgba(13, 148, 136, 0.4);
    transform: translateY(-2px);
  }

  .date-chip.active {
    background: #0D9488;
    border-color: #0D9488;
    box-shadow: 0 0 15px rgba(13, 148, 136, 0.4);
  }

  .date-day-name {
    font-size: 11px;
    text-transform: uppercase;
    color: #94A3B8;
    margin-bottom: 4px;
    font-weight: 600;
  }

  .date-chip.active .date-day-name {
    color: rgba(255, 255, 255, 0.85);
  }

  .date-formatted {
    font-size: 14px;
    font-weight: 700;
    color: #F8FAFC;
  }

  /* Time slots grid */
  .slots-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
    gap: 10px;
  }

  .time-chip {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 10px;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    color: #F8FAFC;
    cursor: pointer;
    transition: all 0.2s ease;
    border-style: solid;
  }

  .time-chip:hover:not(:disabled) {
    background: rgba(13, 148, 136, 0.1);
    border-color: rgba(13, 148, 136, 0.4);
  }

  .time-chip.active {
    background: #0D9488;
    border-color: #0D9488;
    box-shadow: 0 0 15px rgba(13, 148, 136, 0.4);
  }

  .time-chip.occupied {
    background: rgba(255, 255, 255, 0.01) !important;
    border-color: rgba(255, 255, 255, 0.02) !important;
    color: rgba(255, 255, 255, 0.15) !important;
    text-decoration: line-through;
    cursor: not-allowed;
  }

  /* Form Styling */
  .booking-form {
    margin-top: 40px;
    padding: 28px;
    border-radius: 20px;
  }

  .form-header-title {
    font-size: 18px;
    margin-bottom: 20px;
    font-weight: 600;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-bottom: 10px;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 18px;
  }

  .input-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 600px) {
    .input-grid {
      grid-template-columns: 1fr;
    }
  }

  .input-group label {
    font-size: 13px;
    font-weight: 600;
    color: #94A3B8;
  }

  .input-group input,
  .input-group select {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #F8FAFC;
    padding: 12px 16px;
    border-radius: 12px;
    font-size: 14px;
    transition: all 0.2s ease;
  }

  .input-group select option {
    background-color: #111827;
    color: #F8FAFC;
  }

  .input-group input:focus,
  .input-group select:focus {
    outline: none;
    border-color: #0D9488;
    background: rgba(13, 148, 136, 0.05);
    box-shadow: 0 0 10px rgba(13, 148, 136, 0.2);
  }

  .submit-booking-btn {
    width: 100%;
    background: #0D9488;
    color: #FFFFFF;
    border: none;
    border-radius: 14px;
    padding: 14px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 10px;
  }

  .submit-booking-btn:hover:not(:disabled) {
    background: #0F766E;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(13, 148, 136, 0.3);
  }

  .submit-booking-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Success Card Layout */
  .success-card {
    text-align: center;
    max-width: 550px;
    margin: 0 auto;
  }

  .success-icon {
    font-size: 40px;
    display: block;
    margin-bottom: 12px;
  }

  .success-header h3 {
    font-size: 22px;
    color: #10B981;
    margin-bottom: 8px;
  }

  .success-header p {
    color: #94A3B8;
    font-size: 14px;
  }

  .summary-box {
    margin: 24px 0;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 16px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .summary-item {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
  }

  .summary-item span {
    color: #94A3B8;
  }

  .summary-item strong {
    color: #F8FAFC;
  }

  .telehealth-box, .payment-box {
    margin-top: 24px;
    padding: 20px;
    background: rgba(13, 148, 136, 0.05);
    border: 1px solid rgba(13, 148, 136, 0.15);
    border-radius: 16px;
    text-align: left;
  }

  .telehealth-box h4, .payment-box h4 {
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 8px;
    color: #0D9488;
  }

  .telehealth-box p, .payment-box p {
    font-size: 13px;
    color: #CBD5E1;
    line-height: 1.5;
    margin-bottom: 16px;
  }

  .jitsi-link-btn {
    display: block;
    text-align: center;
    background: #0D9488;
    color: #FFFFFF;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
    padding: 10px 16px;
    border-radius: 10px;
    transition: all 0.2s ease;
  }

  .jitsi-link-btn:hover {
    background: #0F766E;
  }

  .pix-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .pix-qr {
    background: #FFFFFF;
    color: #090D16;
    width: 140px;
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    border-radius: 12px;
    border: 4px solid #E2E8F0;
  }

  .pix-btn {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #F8FAFC;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 600;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .pix-btn:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .specialty-chip {
    background: rgba(13, 148, 136, 0.12);
    border: 1px solid rgba(13, 148, 136, 0.3);
    color: #0D9488;
    font-size: 12px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 20px;
  }

  .error-alert {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
    color: #EF4444;
    padding: 12px;
    border-radius: 10px;
    font-size: 13px;
    margin-bottom: 20px;
    font-weight: 500;
  }

  .no-slots {
    color: #94A3B8;
    font-size: 14px;
    text-align: center;
    padding: 20px 0;
  }

  .booking-column {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  /* Fade in animation */
  .fade-in {
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Price box styles */
  .price-section {
    width: 100%;
    margin-top: 10px;
  }
  .price-box {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 16px;
    text-align: center;
  }
  .price-label {
    font-size: 12px;
    color: #94A3B8;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: block;
    margin-bottom: 4px;
  }
  .session-price {
    font-size: 24px;
    color: #0D9488;
    font-weight: 800;
    font-family: 'Outfit', sans-serif;
  }

  /* ----------------------------------------------------
     MOBILE RESPONSIVENESS AND SPACE OPTIMIZATION
     ---------------------------------------------------- */
  @media (max-width: 600px) {
    .grid-layout {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    /* Reduce padding on the global container and card containers */
    .main-container {
      padding: 16px 10px 60px 10px !important;
    }

    .glass-card {
      padding: 20px 16px !important;
      border-radius: 18px !important;
    }

    /* Premium Horizontal Scroll Swipe for Date Chips (Native feeling) */
    .dates-grid {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 10px;
      margin-bottom: 4px;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      gap: 8px;
    }

    /* Subtle custom scrollbar for the horizontal slider */
    .dates-grid::-webkit-scrollbar {
      height: 4px;
    }
    .dates-grid::-webkit-scrollbar-thumb {
      background: rgba(13, 148, 136, 0.25);
      border-radius: 2px;
    }

    .date-chip {
      flex: 0 0 72px;
      min-width: 72px;
      padding: 10px 4px;
      border-radius: 12px;
    }

    /* Clean 3-column slots layout to avoid vertical stretching */
    .slots-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .time-chip {
      padding: 10px 4px;
      font-size: 13px;
      border-radius: 10px;
    }

    /* Compact Form Fields */
    .booking-form {
      margin-top: 24px;
      padding: 18px 14px;
      border-radius: 16px;
    }

    .form-header-title {
      font-size: 16px;
      margin-bottom: 16px;
      padding-bottom: 8px;
    }

    .input-group {
      margin-bottom: 14px;
      gap: 6px;
    }

    .input-group label {
      font-size: 12px;
    }

    .input-group input,
    .input-group select {
      padding: 10px 14px;
      font-size: 13px;
      border-radius: 10px;
    }

    .submit-booking-btn {
      padding: 12px;
      font-size: 14px;
      border-radius: 12px;
    }

    /* Therapist card collapsed profile view on mobile */
    .profile-header {
      flex-direction: row;
      align-items: center;
      text-align: left;
      gap: 16px;
      width: 100%;
    }

    .profile-info {
      align-items: flex-start;
      text-align: left;
      width: calc(100% - 96px); /* 80px avatar + 16px gap */
    }

    .therapist-avatar {
      width: 80px;
      height: 80px;
      border-width: 2px;
      margin-bottom: 0;
    }

    .therapist-name {
      font-size: 18px;
      margin-bottom: 2px;
    }

    .therapist-crp {
      font-size: 12px;
    }

    .therapist-bio {
      font-size: 13px;
      line-height: 1.5;
      text-align: left;
    }

    .separator {
      margin: 16px 0;
    }

    /* Success Card layout adjustments */
    .summary-box {
      padding: 14px;
      margin: 16px 0;
      gap: 8px;
    }

    .summary-item {
      font-size: 13px;
    }

    .telehealth-box, .payment-box {
      padding: 14px;
      margin-top: 16px;
    }

    .pix-qr {
      width: 120px;
      height: 120px;
    }
  }
</style>
